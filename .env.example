# PostgreSQL connection string.
# For psycopg2 (the driver listed in requirements.txt) use the postgresql:// scheme.
# Example for a local Postgres 18 instance:
DATABASE_URL=postgresql://project1:your_secure_password@localhost:5432/project1

# Secret key used to sign session cookies. Change to a long random string in production.
SESSION_SECRET_KEY=change-me-to-a-long-random-secret

# ---------------------------------------------------------------------------
# Development-only admin seeding
# When both SEED_ADMIN_USERNAME and SEED_ADMIN_PASSWORD are set, the app will
# automatically create this user on startup if they do not already exist.
# Leave these UNSET in production (the feature is disabled when they are absent).
# ---------------------------------------------------------------------------
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=changeme
# SEED_ADMIN_ROLE defaults to "admin" when omitted.
# Valid values: admin, pilot, copilot, technician
SEED_ADMIN_ROLE=admin
